# GitHub GraphQL — contribution calendar on the home page
GITHUB_TOKEN=

# Resend — contact form (https://resend.com)
RESEND_API_KEY=
# Verified sender in Resend, e.g. "Portfolio <onboarding@resend.dev>"
RESEND_FROM_EMAIL=
# Where contact form mail is delivered (defaults to mehbubwork@gmail.com if unset)
CONTACT_TO_EMAIL=

# Optional: Upstash Redis for contact form rate limiting (omit to skip rate limits locally)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional: API Ninjas — random quote section (falls back to a default quote if unset)
API_NINJA_API_KEY=
